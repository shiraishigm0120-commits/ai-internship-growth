# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"
# For production (Supabase):
# DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true&connection_limit=1"

# NextAuth (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-key-change-in-production"

# OpenAI-compatible API (leave empty for demo mode with simulated AI responses)
# Supports any OpenAI-compatible provider (e.g., https://ai.luminai.cc)
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-4o"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
